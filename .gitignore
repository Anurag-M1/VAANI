# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Frontend ───────────────────────────────────────────────────────────────

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ─── Backend ────────────────────────────────────────────────────────────────

backend/node_modules/
backend/.env

# ─── Env files ──────────────────────────────────────────────────────────────

.env.local
.env*.local
# (keep .env.example files tracked)
!backend/.env.example

# ─── Misc ───────────────────────────────────────────────────────────────────

.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
