# ============================================================
# VAANI Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5001

# MongoDB Connection
# Local:  mongodb://localhost:27017/vaani
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net/vaani
MONGODB_URI=mongodb://localhost:27017/vaani

# JWT Secrets — use strong random strings in production!
JWT_SECRET=vaani-jwt-secret-change-in-production
REFRESH_TOKEN_SECRET=vaani-refresh-secret-change-in-production

# Demo Mode — enables OTP bypass (OTP: 123456)
# Set to false in production
DEMO_MODE=true

# Cloudinary — for image uploads (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis — for Bull job queues (optional, falls back to in-memory)
REDIS_URL=redis://localhost:6379
